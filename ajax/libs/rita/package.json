{
  "name": "rita",
  "version": "2.0.20",
  "author": "Daniel C. Howe",
  "license": "GPL-3.0",
  "description": "A toolkit for generative natural language",
  "homepage": "https://rednoise.org/rita",
  "repository": {
    "type": "git",
    "url": "https://github.com/dhowe/ritajs.git"
  },
  "np": {
    "contents": "dist"
  },
  "files": [
    "dist"
  ],
  "main": "dist/rita.js",
  "unpkg": "dist/rita-web.js",
  "scripts": {
    "clean": "rm -f dist/*.*",
    "build": "yarn clean && webpack",
    "test": "mocha",
    "watch": "webpack --watch"
  },
  "nyc": {
    "include": "src"
  },
  "watch": {
    "compile": {
      "patterns": "grammar",
      "extensions": "g4"
    }
  },
  "dependencies": {
    "antlr4": "4.8.0",
    "deepmerge": "^4.2.2",
    "flatted": "^2.0.2",
    "he": "^1.2.0"
  },
  "devDependencies": {
    "npe": "^1.1.3",
    "chai": "^4.2.0",
    "codecov": "^3.8.1",
    "mocha": "^6.2.2",
    "npm-watch": "^0.6.0",
    "nyc": "^15.1.0",
    "webpack": "^4.41.2",
    "webpack-bundle-analyzer": "^4.1.0",
    "webpack-cli": "^3.3.10"
  },
  "autoupdate": {
    "source": "npm",
    "target": "rita",
    "fileMap": [
      {
        "basePath": "dist",
        "files": [
          "*.js"
        ]
      }
    ]
  },
  "keywords": [
    "natural language",
    "generative text",
    "text analysis"
  ]
}
