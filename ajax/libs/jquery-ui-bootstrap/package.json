{
  "name": "jquery-ui-bootstrap",
  "description": "A Bootstrap-themed kickstart for jQuery UI widgets",
  "filename": "assets/css/bootstrap.min.css",
  "keywords": [
    "jquery",
    "bootstrap"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jquery-ui-bootstrap/jquery-ui-bootstrap"
  },
  "license": "MIT",
  "autoupdate": {
    "source": "git",
    "target": "git://github.com/jquery-ui-bootstrap/jquery-ui-bootstrap.git",
    "fileMap": [
      {
        "basePath": "assets",
        "files": [
          "**/*"
        ]
      },
      {
        "basePath": "css/custom-theme",
        "files": [
          "**/*"
        ]
      },
      {
        "basePath": "third-party",
        "files": [
          "**/*"
        ]
      }
    ]
  }
}
