{
  "name": "openlayers",
  "filename": "ol.js",
  "version": "4.6.5",
  "description": "OpenLayers is a JavaScript library for building map applications on the web.",
  "homepage": "http://openlayers.org/",
  "license": "BSD-2-Clause",
  "keywords": [
    "map",
    "openlayers",
    "ol",
    "maps"
  ],
  "autoUpdate": {
    "source": "git",
    "target": "git://github.com/openlayers/openlayers.github.io.git/en/latest#master"
  },
  "fileMap": [{
    "basePath": "build",
    "files": [
      "ol.js*"
    ]
  }, {
    "basePath": "css",
    "files": [
      "ol.css*"
    ]
  }],
  "repository": {
    "type": "git",
    "url": "https://github.com/openlayers/openlayers"
  }
}
