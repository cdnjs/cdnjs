var J;

import {
  refresh,
  preUrl,
  setUrl
} from 'x/route.js';

import split from 'x/split.js';

import removeSlash from 'x/removeSlash.js';

J = '#';

export default (url) => {
  var purl;
  url = removeSlash(url);
  purl = preUrl();
  if (url === purl) {
    return;
  }
  setUrl(url);
  if (split(url, J)[0] !== split(purl, J)[0]) {
    refresh(url);
  }
};
