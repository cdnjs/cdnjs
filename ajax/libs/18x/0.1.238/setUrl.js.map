var SLASH;

import {
  setPre
} from 'x/route.js';

import removeSlash from 'x/removeSlash.js';

SLASH = '/';

export default (url) => {
  setPre(removeSlash(url));
  if (url.charAt(0) !== SLASH) {
    url = SLASH + url;
  }
  history.pushState(null, '', url);
  window.dispatchEvent(new HashChangeEvent('hashchange'));
};
