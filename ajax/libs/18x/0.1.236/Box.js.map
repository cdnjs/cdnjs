import On from 'x/On.js';

export default () => {
  var body, dialog, doc;
  ({body} = doc = document);
  dialog = doc.createElement('dialog');
  dialog.className = 'uBox';
  On(dialog, {
    close: () => {
      body.removeChild(dialog);
    }
  });
  body.prepend(dialog);
  dialog.addEventListener('cancel', (e) => {
    e.preventDefault();
  });
  setTimeout(() => { // 不这样 chrome 122.0.6261.129 在 vite 开发模式下有时候会没法显示在顶部
    dialog.showModal();
  });
  return dialog;
};
