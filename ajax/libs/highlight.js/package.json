{
  "name": "highlight.js",
  "filename": "highlight.min.js",
  "version": "9.0.0",
  "description": "Syntax highlighting with language autodetection.",
  "homepage": "http://highlightjs.org",
  "keywords": [
    "highlight",
    "syntax highlighter"
  ],
  "autoupdate": {
    "source": "git",
    "target": "git://github.com/highlightjs/cdn-release.git",
    "basePath": "build",
    "files": [
      "highlight.min.js",
      "languages/*.min.js",
      "styles/*"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/isagalaev/highlight.js"
  },
  "license": "BSD-3-Clause",
  "author": {
    "name": "Ivan Sagalaev",
    "email": "maniac@softwaremaniacs.org"
  }
}
