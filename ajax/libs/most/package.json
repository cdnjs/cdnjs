{
  "name": "most",
  "filename": "most.min.js",
  "version": "1.0.0",
  "description": "Monadic streams",
  "repository": {
    "type": "git",
    "url": "https://github.com/cujojs/most"
  },
  "keywords": [
    "reactive",
    "reactive programming",
    "reactive streams",
    "streams",
    "event stream",
    "promises",
    "promises-aplus",
    "fantasy-land",
    "monad",
    "monadic",
    "functional",
    "async",
    "cujojs",
    "cujo"
  ],
  "author": "Brian Cavalier <brian@hovercraftstudios.com>",
  "license": "MIT",
  "dependencies": {
    "@most/multicast": "^1.1.1",
    "@most/prelude": "^1.2.0",
    "symbol-observable": "^0.2.4"
  },
  "npmName": "most",
  "npmFileMap": [
    {
      "basePath": "",
      "files": [
        "most*"
      ]
    },
    {
      "basePath": "lib",
      "files": [
        "source/+(core|from|periodic|fromEvent|unfold|iterate|generate)*",
        "combinator/*",
        "observable/subscribe*"
      ]
    }
  ]
}
