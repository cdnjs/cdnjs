    "animation"
  ],
  "homepage": "https://d3js.org/d3-transition/",
  "license": "BSD-3-Clause",
  "author": {
    "name": "Mike Bostock",
    "url": "https://bost.ocks.org/mike"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/d3/d3-transition.git"
  },
  "version": "1.1.1",
  "autoupdate": {
    "source": "npm",
    "target": "d3-transition",
    "fileMap": [
      {
        "basePath": "build",
