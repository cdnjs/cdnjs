{
    "name": "highlightjs.loader",
    "title": "Highlight JS Loader",
    "filename": "highlightjs.loader.min.js",
    "version": "6.1",
    "description": "Highlight.js loader, highlightjs plugin, syntax highlighter, line numbers, fix css, hljs, hjln",
    "author": "Ali.Debugger",
    "homepage": "https://highlightjs.org/",
    "repositories": [
        {
            "type": "git",
            "url": "git://github.com/alidbg/highlight.js_loader.git"
        }
    ],
    "keywords": [
        "highlight.js",
        "highlightjs",
        "scrollbar",
        "line numbers",
        "snippet",
        "loader",
        "hljs",
        "syntax",
        "code"
    ],
    "autoupdate": {
        "source": "git",
        "target": "git://github.com/alidbg/highlight.js_loader.git",
        "basePath": "",
        "files": [
            "highlightjs.loader.min.js",
            "highlightjs.loader.js",
            "./src/**/*"
        ],
        "exclude": [
            "./src/jquery.js",
            "./src/highlight.js",
            "./src/monokai_sublime.css"
        ]
    },
    "dependencies": {
        "highlight.js": ">=8.2"
    }
}
