{
    "name": "Highlight JS Loader",
    "title": "Highlight JS Loader",
    "filename": "highlightjs.loader.min.js",
    "version": "6.0",
    "description": "Highlight.js loader, highlightjs plugin, syntax highlighter, line numbers, encode tags, scrollbar, fix css, hljs, hjln",
    "author": "Ali.Debugger",
    "homepage": "https://github.com/alidbg/highlight.js_loader",
    "repositories": [
        {
            "type": "git",
            "url": "git://github.com/alidbg/highlight.js_loader.git"
        }
    ],
    "keywords": [
        "highlight.js",
        "highlighter",
        "highlightjs",
        "scrollbar",
        "line numbers",
        "snippet",
        "loader",
        "hljs",
        "syntax",
        "code",
        "css",
        "encode",
        "tags",
        "html entities"
    ],
    "autoupdate": {
        "source": "git",
        "target": "git://github.com/alidbg/highlight.js_loader.git",
        "basePath": "",
        "files": [
            "highlightjs.loader.min.js",
            "highlightjs.loader.js",
            "./src/**/*"
        ],
        "exclude": [
            "./src/jquery.js",
            "./src/highlight.js",
            "./src/monokai_sublime.css"
        ]
    },
    "dependencies": {
        "highlight.js": ">=8.2"
    },
    "licenses": [
        {
            "type": "MIT",
            "url": "http: //en.wikipedia.org/wiki/MIT_License"
        }
    ],
    "docs": "http://highlightjs.readthedocs.org/en/latest/",
    "demo": "http://codepen.io/alidbg/pen/EaQLeO",
    "bugs": "https://github.com/alidbg/highlight.js_loader/issues/"
}
