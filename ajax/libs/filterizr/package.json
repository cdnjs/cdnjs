{
  "name": "filterizr",
  "filename": "jquery.filterizr.min.js",
  "version": "1.2.4",
  "description": "Filterizr is a jQuery plugin that sorts, shuffles, searches and applies stunning filters over responsive galleries using CSS3 transitions and custom CSS effects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giotiskl/Filterizr.git"
  },
  "keywords": [
    "filter",
    "shuffle",
    "search",
    "sort",
    "filterizr",
    "gallery",
    "responsive",
    "css3",
    "css",
    "lightweight",
    "customizable",
    "Yiotis",
    "jquery-plugin",
    "ecosystem:jquery"
  ],
  "author": "Yiotis Kaltsikis <yiotiskal@gmail.com>",
  "license": "MIT",
  "homepage": "http://yiotis.net/filterizr/",
  "npmName": "filterizr",
  "npmFileMap": [
    {
      "basePath": "dist",
      "files": [
        "**/*"
      ]
    },
    {
      "basePath": "src",
      "files": [
        "jquery.filterizr*"
      ]
    }
  ]
}
